{
  "name": "@rataqa/amir",
  "version": "1.0.2",
  "description": "Common workers that can integrate with AMQP broker",
  "type": "commonjs",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "build:ts": "tsc --project tsconfig.build.json",
    "build": "npm-run-all clean build:ts",
    "test": "node -r ts-node/register --test src/__tests__/*.test.ts",
    "test:coverage": "node -r ts-node/register --experimental-test-coverage --test src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@rataqa/sijil": "^1.0.4",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "homepage": "https://github.com/rataqa/amir#readme",
  "bugs": {
    "url": "https://github.com/rataqa/amir/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rataqa/amir.git"
  },
  "license": "MIT",
  "author": "Rataqa Team",
  "keywords": [
    "worker",
    "amqp",
    "broker",
    "message",
    "queue"
  ]
}
